# Variaveis do BackEnd (defina na Vercel, projeto do BackEnd, em Production).

# Connection string POOLED do Neon Postgres (com sslmode=require).
# As tabelas teams/members sao criadas automaticamente na 1a chamada.
DATABASE_URL=

# Token exigido para lancar nota / excluir time (header x-admin-token).
# Deve ser IGUAL ao token digitado no painel /admin do FrontEnd.
# Demo do front: capivara-2026
ADMIN_TOKEN=

# (Opcional) Restringe o CORS a um unico dominio (o do FrontEnd).
# Se vazio, libera para qualquer origem (*). Ex.: https://desafio-ia.vercel.app
ALLOWED_ORIGIN=
